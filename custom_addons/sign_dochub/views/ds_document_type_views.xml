<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ============================================================ -->
        <!-- DS DOCUMENT TYPE: List View -->
        <!-- ============================================================ -->
        <record id="ds_document_type_view_list" model="ir.ui.view">
            <field name="name">ds.document.type.list</field>
            <field name="model">ds.document.type</field>
            <field name="arch" type="xml">
                <list string="Document Types" editable="bottom">
                    <field name="code"/>
                    <field name="name"/>
                    <field name="sequence_id"/>
                    <field name="default_template_id"/>
                </list>
            </field>
        </record>

        <!-- ============================================================ -->
        <!-- DS DOCUMENT TYPE: Form View -->
        <!-- ============================================================ -->
        <record id="ds_document_type_view_form" model="ir.ui.view">
            <field name="name">ds.document.type.form</field>
            <field name="model">ds.document.type</field>
            <field name="arch" type="xml">
                <form string="Document Type">
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="code"/>
                            </group>
                            <group>
                                <field name="sequence_id"/>
                                <field name="default_template_id"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- ============================================================ -->
        <!-- DS DOCUMENT TYPE: Action -->
        <!-- ============================================================ -->
        <record id="ds_document_type_action" model="ir.actions.act_window">
            <field name="name">Document Types</field>
            <field name="res_model">ds.document.type</field>
            <field name="view_mode">list,form</field>
        </record>

    </data>
</odoo>
