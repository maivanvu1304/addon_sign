<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ============================================================ -->
        <!-- DS DOCUMENT TEMPLATE: List View -->
        <!-- ============================================================ -->
        <record id="ds_document_template_view_list" model="ir.ui.view">
            <field name="name">ds.document.template.list</field>
            <field name="model">ds.document.template</field>
            <field name="arch" type="xml">
                <list string="Workflow Templates">
                    <field name="name"/>
                    <field name="description"/>
                    <field name="company_id" groups="base.group_multi_company"/>
                </list>
            </field>
        </record>

        <!-- ============================================================ -->
        <!-- DS DOCUMENT TEMPLATE: Form View -->
        <!-- ============================================================ -->
        <record id="ds_document_template_view_form" model="ir.ui.view">
            <field name="name">ds.document.template.form</field>
            <field name="model">ds.document.template</field>
            <field name="arch" type="xml">
                <form string="Workflow Template">
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="active"/>
                            </group>
                            <group>
                                <field name="company_id" groups="base.group_multi_company"/>
                            </group>
                        </group>
                        <field name="description" placeholder="Template description..."/>
                        <separator string="Steps"/>
                        <field name="step_ids">
                            <list editable="bottom">
                                <field name="sequence" widget="handle"/>
                                <field name="name"/>
                                <field name="role"/>
                                <field name="user_id"/>
                                <field name="is_external"/>
                                <field name="partner_id" invisible="not is_external"/>
                            </list>
                        </field>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- ============================================================ -->
        <!-- DS DOCUMENT TEMPLATE: Action -->
        <!-- ============================================================ -->
        <record id="ds_document_template_action" model="ir.actions.act_window">
            <field name="name">Workflow Templates</field>
            <field name="res_model">ds.document.template</field>
            <field name="view_mode">list,form</field>
        </record>

    </data>
</odoo>
