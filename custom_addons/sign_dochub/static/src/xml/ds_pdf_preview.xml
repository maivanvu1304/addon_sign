<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="ds_sign.DsPdfPreviewPanel">

        <!-- ===== STATE: adjusting → PDF Viewer with placed sign positions ===== -->
        <t t-if="isAdjusting">
            <div class="ds_pdf_preview_panel d-flex flex-column h-100 border-start bg-light">

                <!-- Panel Header -->
                <div class="ds_pdf_preview__header d-flex align-items-center justify-content-between px-3 py-2 bg-white border-bottom">
                    <div class="ds_pdf_preview__title fw-semibold">
                        <i class="fa fa-file-pdf-o me-1 text-danger"/> Xem trước vị trí ký
                    </div>
                    <!-- Page nav -->
                    <div class="ds_pdf_preview__page-nav d-flex align-items-center">
                        <button class="btn btn-sm btn-light border px-2 py-0"
                                t-on-click="prevPage"
                                t-att-disabled="state.currentPage === 1">
                            <i class="fa fa-chevron-up"/>
                        </button>
                        <span class="ds_pdf_preview__page-info">
                            <t t-esc="state.currentPage"/> / <t t-esc="state.totalPages"/>
                        </span>
                        <button class="btn btn-sm btn-light border px-2 py-0"
                                t-on-click="nextPage"
                                t-att-disabled="state.currentPage === state.totalPages">
                            <i class="fa fa-chevron-down"/>
                        </button>
                    </div>
                </div>

                <!-- PDF Canvas area -->
                <div class="ds_pdf_preview__canvas-area flex-grow-1 overflow-auto d-flex justify-content-center align-items-start p-2"
                     t-ref="canvasArea">

                    <t t-if="state.loading">
                        <div class="ds_pdf_preview__loading d-flex justify-content-center align-items-center w-100">
                            <i class="fa fa-spinner fa-spin fa-2x text-muted"/>
                        </div>
                    </t>

                    <t t-elif="!state.pdfUrl">
                        <div class="ds_pdf_preview__no-pdf alert alert-warning m-3">
                            Chưa có file PDF đính kèm.
                        </div>
                    </t>

                    <t t-else="">
                        <!-- PDF container with signature overlays -->
                        <div class="ds_pdf_preview__pdf-container"
                             t-ref="pdfContainer">

                            <canvas t-ref="pdfCanvas"/>

                            <!-- Signature position boxes (read-only overlay) -->
                            <t t-foreach="state.signers" t-as="signer" t-key="'box_' + signer.item_id">
                                <t t-if="signer.placed and signer.page === state.currentPage">
                                    <div class="ds_sign_overlay_box"
                                         t-att-style="getSignerStyle(signer)">
                                        <div class="ds_sign_overlay_box__name text-center">
                                            <t t-esc="signer.name"/>
                                        </div>
                                        <div class="ds_sign_overlay_box__state">
                                            <t t-esc="signerStateLabel(signer.itemState)"/>
                                        </div>
                                    </div>
                                </t>
                            </t>
                        </div>
                    </t>
                </div>
            </div>
        </t>


    </t>

</templates>
